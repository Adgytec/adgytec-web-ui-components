{
    "name": "@adgytec/adgytec-web-ui-components",
    "private": false,
    "version": "1.1.5",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "generate:index": "node src/scripts/generate-root-index.mjs",
        "build": "npm run generate:index && npm run lint  && npm run typecheck && vite build",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "tsc -b",
        "preview": "vite preview",
        "release": "npm run build && npm publish --public",
        "test": "echo \"No tests\""
    },
    "peerDependencies": {
        "clsx": ">=2.1.1",
        "lucide-react": "^1.8.0",
        "react": ">=19.2.3",
        "react-aria-components": ">=1.14.0",
        "react-dom": ">=19.2.3",
        "sonner": ">=2.0.7",
        "usehooks-ts": ">=3.1.1",
        "zod": ">=4.3.5"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.8",
        "@csstools/postcss-global-data": "^4.0.0",
        "@react-aria/optimize-locales-plugin": "^1.1.5",
        "@types/node": "^25.3.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react-swc": "^4.2.3",
        "autoprefixer": "^10.4.27",
        "clsx": "^2.1.1",
        "glob": "^13.0.6",
        "globals": "^17.4.0",
        "lightningcss": "^1.31.1",
        "lucide-react": "^1.8.0",
        "postcss-custom-media": "^12.0.1",
        "postcss-nesting": "^14.0.0",
        "react": "^19.2.4",
        "react-aria-components": "^1.15.1",
        "react-dom": "^19.2.4",
        "sonda": "^0.11.1",
        "sonner": "^2.0.7",
        "typescript": "~5.9.3",
        "usehooks-ts": "^3.1.1",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-lib-inject-css": "^2.2.2",
        "vite-plugin-static-copy": "^3.2.0",
        "zod": "^4.3.6"
    },
    "author": {
        "name": "Adgytec",
        "email": "rohan@adgytec.in",
        "url": "https://adgytec.in"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Adgytec/adgytec-web-ui-components.git"
    },
    "homepage": "https://github.com/Adgytec/adgytec-web-ui-components/#/README.md"
}
