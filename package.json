{
    "name": "@adgytec/adgytec-web-ui-components",
    "private": false,
    "version": "1.1.3",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "generate:index": "node src/scripts/generate-root-index.mjs",
        "build": "npm run generate:index && tsc -b ./tsconfig.app.json && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "release": "npm run build && npm publish --public",
        "test": "npm run build && npm pack"
    },
    "peerDependencies": {
        "lucide-react": ">=0.562.0",
        "react": ">=19.2.3",
        "react-aria-components": ">=1.14.0",
        "react-dom": ">=19.2.3",
        "sonner": ">=2.0.7",
        "usehooks-ts": ">=3.1.1",
        "zod": ">=4.3.5",
        "clsx": ">=2.1.1"
    },
    "devDependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-aria-components": "^1.15.1",
        "lucide-react": "^0.575.0",
        "sonner": "^2.0.7",
        "usehooks-ts": "^3.1.1",
        "zod": "^4.3.6",
        "clsx": "^2.1.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@eslint/js": "^9.39.2",
        "eslint": "^9.39.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "typescript-eslint": "^8.56.1",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "@vitejs/plugin-react-swc": "^4.2.3",
        "vite-plugin-dts": "^4.5.4",
        "vite-plugin-lib-inject-css": "^2.2.2",
        "vite-plugin-static-copy": "^3.2.0",
        "prettier": "^3.8.1",
        "autoprefixer": "^10.4.27",
        "lightningcss": "^1.31.1",
        "glob": "^13.0.6",
        "globals": "^17.4.0",
        "@types/node": "^25.3.3",
        "@react-aria/optimize-locales-plugin": "^1.1.5"
    },
    "author": {
        "name": "Adgytec",
        "email": "rohan@adgytec.in",
        "url": "https://adgytec.in"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Adgytec/adgytec-web-ui-components.git"
    },
    "homepage": "https://github.com/Adgytec/adgytec-web-ui-components/#/README.md"
}
