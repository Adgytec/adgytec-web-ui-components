{
    "name": "@adgytec/adgytec-web-ui-components",
    "private": false,
    "version": "2.1.0",
    "type": "module",
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./styles/core.css": {
            "import": "./dist/assets/core.css"
        },
        "./styles/defaultTheme.css": {
            "import": "./dist/assets/defaultTheme.css"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "vite",
        "dev-host": "vite --host",
        "generate:index": "node src/scripts/generate-root-index.mjs",
        "build": "npm run generate:index && npm run lint  && npm run typecheck && vite build",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "tsc -b",
        "preview": "vite preview",
        "release": "npm run build && npm publish --public",
        "test": "echo \"No tests\""
    },
    "peerDependencies": {
        "@internationalized/date": "^3.12.1",
        "clsx": ">=2.1.1",
        "lucide-react": "^1.8.0",
        "react": ">=19.2.3",
        "react-aria": "^3.48.0",
        "react-aria-components": ">=1.17.0",
        "react-dom": ">=19.2.3",
        "react-transition-group": "^4.4.5",
        "usehooks-ts": ">=3.1.1",
        "zod": ">=4.3.5"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@csstools/postcss-global-data": "^4.0.0",
        "@internationalized/date": "^3.12.1",
        "@react-aria/optimize-locales-plugin": "^1.2.0",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@types/react-transition-group": "^4.4.12",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "autoprefixer": "^10.5.0",
        "clsx": "^2.1.1",
        "glob": "^13.0.6",
        "globals": "^17.6.0",
        "lightningcss": "^1.32.0",
        "lucide-react": "^1.16.0",
        "postcss-custom-media": "^12.0.1",
        "postcss-nesting": "^14.0.0",
        "react": "^19.2.6",
        "react-aria": "^3.48.0",
        "react-aria-components": "^1.17.0",
        "react-dom": "^19.2.6",
        "react-transition-group": "^4.4.5",
        "sonda": "^0.11.1",
        "typescript": "~6.0.3",
        "usehooks-ts": "^3.1.1",
        "vite": "^8.0.14",
        "vite-plugin-dts": "^5.0.1",
        "vite-plugin-lib-inject-css": "^2.2.2",
        "vite-plugin-static-copy": "^4.1.0",
        "zod": "^4.4.3"
    },
    "author": {
        "name": "Adgytec",
        "email": "rohan@adgytec.in",
        "url": "https://adgytec.in"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Adgytec/adgytec-web-ui-components.git"
    },
    "homepage": "https://github.com/Adgytec/adgytec-web-ui-components/#/README.md"
}
